# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only (do not expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_PROJECT_ID=your-project-id-here

# Payment Gateway Configuration
# These are configured through the UI, not environment variables
# But you can optionally set defaults here
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=optional-paystack-public-key
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=optional-flutterwave-public-key

# NextAuth Configuration (optional)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-hex-32

# CheqPay backend (apps/api) — for admin-only settings (Trading Settings page).
# ADMIN_API_SECRET must match the backend's ADMIN_API_SECRET. Server-side only.
CHEQPAY_API_URL=http://localhost:4000
ADMIN_API_SECRET=must-match-backend-admin-secret-16+chars
