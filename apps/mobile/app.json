{
  "expo": {
    "name": "CheqPay",
    "slug": "cheqpay",
    "version": "1.0.0",
    "scheme": "cheqpay",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#14121A"
    },
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.cheqpay.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.cheqpay.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow CheqPay to use Face ID to unlock the app."
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      [
        "expo-alternate-app-icons",
        [
          {
            "name": "Midnight",
            "ios": "./assets/icons/icon-midnight.png",
            "android": {
              "foregroundImage": "./assets/icons/icon-midnight.png",
              "backgroundColor": "#14121A"
            }
          },
          {
            "name": "Mint",
            "ios": "./assets/icons/icon-mint.png",
            "android": {
              "foregroundImage": "./assets/icons/icon-mint.png",
              "backgroundColor": "#34C759"
            }
          },
          {
            "name": "Gold",
            "ios": "./assets/icons/icon-gold.png",
            "android": {
              "foregroundImage": "./assets/icons/icon-gold.png",
              "backgroundColor": "#F5A623"
            }
          }
        ]
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
