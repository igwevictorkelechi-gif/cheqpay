# ---- Runtime ----
NODE_ENV="development"

# ---- Database (Supabase Postgres) — Phase 2 ----
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ---- Auth — Phase 1 ----
# Supabase Auth issues the JWTs; copy the project's JWT secret here so the API
# can verify them. (Supabase dashboard -> Settings -> API -> JWT Secret.)
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"
# Admin auth — service secret (backend-to-backend, e.g. admin dashboard proxy)
ADMIN_API_SECRET="generate-a-strong-16+char-secret"
# Admin auth — allowlist of admin user emails (comma-separated). Admins are
# Supabase users with app_metadata.role="admin" OR an email listed here.
ADMIN_EMAILS=""

# ---- AML (Phase 6) — thresholds in whole NGN ----
AML_LARGE_AMOUNT_NGN="1000000"        # flag single withdrawals at/above this
AML_REVIEW_THRESHOLD_NGN="5000000"    # hold for manual review at/above this
AML_VELOCITY_COUNT="10"               # withdrawals/day before review
AML_VELOCITY_SUM_NGN="10000000"       # daily withdrawal sum before review
SANCTIONED_ADDRESSES=""               # comma-separated blocked addresses

# ---- Custody — Phase 2 ----
# "mock" (default, no external calls) or "maplerad" (stablecoin: USDT/USDC on
# ERC-20; reuses MAPLERAD_SECRET_KEY below). No provider offers BTC — it stays
# "coming soon". NOTE: crypto_deposits / crypto_withdrawals feature flags
# default OFF (compliance + a Maplerad-side sandbox bug); flip them in the
# admin dashboard only after VASP registration and a verified sandbox run.
CUSTODY_PROVIDER="mock"
TATUM_API_KEY=""          # legacy
TATUM_WEBHOOK_SECRET=""   # legacy — HMAC-SHA512 secret for old deposit webhooks

# ---- Naira rail — Phase 3 ----
# "mock" (default, no external calls) or "maplerad" (requires the keys below).
# Maplerad runs bills (airtime/data/electricity/cable), payouts, name enquiry and
# the bank list. NGN deposits are NOT live: Maplerad has not enabled collections
# on the business yet, so virtual-account creation fails by design.
#
# Before switching to "maplerad": reconcile the bills catalog prices in
# src/lib/bills.ts against Maplerad's real bundle/plan prices — data and cable are
# matched by EXACT price, so a mismatched plan cannot be bought.
PAYMENT_PROVIDER="mock"
MAPLERAD_SECRET_KEY=""        # sandbox or live secret key (live requires a whitelisted egress IP)
MAPLERAD_BASE_URL="https://api.maplerad.com/v1"
MAPLERAD_WEBHOOK_SECRET=""    # Svix signing secret (whsec_...) — verifies payout settlement webhooks

# ---- Rates / market data — Phase 4 ----
# "live" (Binance + CoinGecko fallback) or "mock" (deterministic, for tests).
PRICE_FEED="live"
BINANCE_API_BASE="https://api.binance.com"
BUSINESS_USDT_NGN_RATE=""   # business-controlled USDT->NGN rate
SWAP_SPREAD_BPS="150"       # 1.5% spread (basis points)
